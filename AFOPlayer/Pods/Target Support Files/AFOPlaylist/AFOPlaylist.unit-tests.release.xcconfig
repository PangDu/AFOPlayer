CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "$(PLATFORM_DIR)/Developer/Library/Frameworks"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/Headers/Private" "${PODS_ROOT}/Headers/Private/AFOPlaylist" "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/AFODelegateExtension" "${PODS_ROOT}/Headers/Public/AFOFFMpeg" "${PODS_ROOT}/Headers/Public/AFOFFMpegLib" "${PODS_ROOT}/Headers/Public/AFOFoundation" "${PODS_ROOT}/Headers/Public/AFOGitHub" "${PODS_ROOT}/Headers/Public/AFOLANUpload" "${PODS_ROOT}/Headers/Public/AFOPlaylist" "${PODS_ROOT}/Headers/Public/AFORouter" "${PODS_ROOT}/Headers/Public/AFOSQLite" "${PODS_ROOT}/Headers/Public/AFOSchedulerCore" "${PODS_ROOT}/Headers/Public/AFOUIKIT" "${PODS_ROOT}/Headers/Public/AFOViews" "${PODS_ROOT}/Headers/Public/AFOlibyuv" "${PODS_ROOT}/Headers/Public/AFOx264" "${PODS_ROOT}/Headers/Public/FMDB" "${PODS_ROOT}/Headers/Public/libxvidcore"
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AFODelegateExtension" "${PODS_CONFIGURATION_BUILD_DIR}/AFOFFMpeg" "${PODS_CONFIGURATION_BUILD_DIR}/AFOFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/AFOGitHub" "${PODS_CONFIGURATION_BUILD_DIR}/AFOLANUpload" "${PODS_CONFIGURATION_BUILD_DIR}/AFOPlaylist" "${PODS_CONFIGURATION_BUILD_DIR}/AFORouter" "${PODS_CONFIGURATION_BUILD_DIR}/AFOSQLite" "${PODS_CONFIGURATION_BUILD_DIR}/AFOSchedulerCore" "${PODS_CONFIGURATION_BUILD_DIR}/AFOUIKIT" "${PODS_CONFIGURATION_BUILD_DIR}/AFOViews" "${PODS_CONFIGURATION_BUILD_DIR}/FMDB" "${PODS_ROOT}/../../../AFOGitHub/AFOGitHub/SDWebImage/lib" "${PODS_ROOT}/AFOFFMpegLib/FFmpeg/lib" "${PODS_ROOT}/AFOlibyuv/libyuv/lib" "${PODS_ROOT}/AFOx264/x264/lib" "${PODS_ROOT}/libxvidcore/libxvidcore/lib"
OTHER_LDFLAGS = $(inherited) -ObjC -l"AFODelegateExtension" -l"AFOFFMpeg" -l"AFOFoundation" -l"AFOGitHub" -l"AFOLANUpload" -l"AFOPlaylist" -l"AFORouter" -l"AFOSQLite" -l"AFOSchedulerCore" -l"AFOUIKIT" -l"AFOViews" -l"FMDB" -l"SDWebImage" -l"avcodec" -l"avformat" -l"avutil" -l"bz2" -l"c" -l"c++" -l"iconv" -l"sqlite3" -l"swresample" -l"swscale" -l"x264" -l"xvidcore" -l"yuv" -l"z" -framework "AVFoundation" -framework "AudioToolbox" -framework "CoreGraphics" -framework "CoreImage" -framework "CoreMedia" -framework "OpenGLES" -framework "VideoToolbox" -framework "XCTest"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_DEVELOPMENT_LANGUAGE = ${DEVELOPMENT_LANGUAGE}
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/../../../AFOPlaylist
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_ROOT}/../../../AFOGitHub/AFOGitHub/SDWebImage/lib" "${PODS_ROOT}/AFOFFMpegLib/FFmpeg/lib" "${PODS_ROOT}/AFOlibyuv/libyuv/lib" "${PODS_ROOT}/AFOx264/x264/lib" "${PODS_ROOT}/libxvidcore/libxvidcore/lib"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
