CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/AFOFFMpeg
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/Headers/Private" "${PODS_ROOT}/Headers/Private/AFOFFMpeg" "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/AFODelegateExtension" "${PODS_ROOT}/Headers/Public/AFOFFMpeg" "${PODS_ROOT}/Headers/Public/AFOFFMpegLib" "${PODS_ROOT}/Headers/Public/AFOFoundation" "${PODS_ROOT}/Headers/Public/AFOGitHub" "${PODS_ROOT}/Headers/Public/AFORouter" "${PODS_ROOT}/Headers/Public/AFOSchedulerCore" "${PODS_ROOT}/Headers/Public/AFOUIKIT" "${PODS_ROOT}/Headers/Public/AFOViews" "${PODS_ROOT}/Headers/Public/AFOlibyuv" "${PODS_ROOT}/Headers/Public/AFOx264" "${PODS_ROOT}/Headers/Public/libxvidcore"
OTHER_LDFLAGS = $(inherited) -l"ObjC"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_DEVELOPMENT_LANGUAGE = ${DEVELOPMENT_LANGUAGE}
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/../../../AFOFFMpeg
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_ROOT}/AFOFFMpegLib/FFmpeg/lib" "${PODS_ROOT}/AFOGitHub/AFOGitHub/SDWebImage/lib" "${PODS_ROOT}/AFOlibyuv/libyuv/lib" "${PODS_ROOT}/AFOx264/x264/lib" "${PODS_ROOT}/libxvidcore/libxvidcore/lib"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
