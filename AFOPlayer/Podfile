platform :ios, '13.0'
inhibit_all_warnings!

target 'AFOPlayer' do
  pod 'AFODelegateExtension'
  pod 'AFOFoundation'
  pod 'AFOGitHub'
  pod 'AFOLANUpload'
  pod 'AFOOnlinePlay'
  pod 'AFOWaterfall'
  pod 'AFOPlaylist'
  pod 'AFORouter'
  pod 'AFOSQLite'
  pod 'AFOSchedulerCore'
  pod 'AFOUIKIT'
  pod 'AFOViews'
  pod 'AFOFFMpeg'
end

post_install do |installer|
  simulator_ldflags = [
    '$(inherited)',
    '-ObjC',
    '-lAFODelegateExtension',
    '-lAFOLANUpload',
    '-lAFOFoundation',
    '-lAFOGitHub',
    '-lAFOPlaylist',
    '-lAFOWaterfall',
    '-lAFOOnlinePlay',
    '-lAFORouter',
    '-lAFOSQLite',
    '-lAFOSchedulerCore',
    '-lAFOUIKIT',
    '-lAFOViews',
    '-lFMDB'
  ]

  iphoneos_ldflags = [
    '$(inherited)',
    '-ObjC',
    '-lAFODelegateExtension',
    '-lAFOLANUpload',
    '-lAFOFFMpeg',
    '-lAFOFoundation',
    '-lAFOGitHub',
    '-lAFOPlaylist',
    '-lAFOWaterfall',
    '-lAFOOnlinePlay',
    '-lAFORouter',
    '-lAFOSQLite',
    '-lAFOSchedulerCore',
    '-lAFOUIKIT',
    '-lAFOViews',
    '-lFMDB',
    '-lSDWebImage',
    '-lavcodec',
    '-lavformat',
    '-lavutil',
    '-lc',
    '-lc++',
    '-lswresample',
    '-lswscale',
    '-lx264',
    '-lxvidcore',
    '-lyuv',
    '-framework AVFoundation',
    '-framework AudioToolbox',
    '-framework CoreGraphics',
    '-framework CoreImage',
    '-framework CoreMedia',
    '-framework OpenGLES',
    '-framework VideoToolbox'
  ]

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      next unless target.name == 'Pods-AFOPlayer'

      config.build_settings['OTHER_LDFLAGS[sdk=iphonesimulator*]'] = simulator_ldflags
      config.build_settings['OTHER_LDFLAGS[sdk=iphoneos*]'] = iphoneos_ldflags
    end
  end
end
